# Secrets and environment-specific overrides only.
# Public settings (port, TTL, CORS, OAuth provider list) live in config.yaml.
# Env always wins over config.yaml when both are set.

# --- Secrets (required in production) ---
DB_PASSWORD=postgres
JWT_SECRET=dev-jwt-secret-change-in-production
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- Docker / deploy overrides (optional) ---
# DB_HOST=postgres
# REDIS_URL=redis://redis:6379
# CACHE_ENABLED=true
# CACHE_DRIVER=redis
# CACHE_DEFAULT_TTL=5m
# CACHE_FILE_DIR=storage/cache
# CACHE_REDIS_URL=redis://redis:6379
# CORS_ORIGINS=http://system.local:8080,http://localhost:8080
# OAUTH_REDIRECT_URL=http://system.local:8080/auth/callback
# CONFIG_FILE=config.yaml
