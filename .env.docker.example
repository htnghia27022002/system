# Copy to .env at repo root: cp .env.docker.example .env

POSTGRES_DB=myapp_pg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# BE secrets (override config.yaml — never commit real values)
JWT_SECRET=dev-jwt-secret-change-in-production
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Local hostname — add once: 127.0.0.1 system.local
APP_HOST=system.local

# nginx host port → container :80
NGINX_HTTP_PORT=80

NEXT_PUBLIC_API_BASE_URL=http://system.local/api
NEXT_PUBLIC_APP_NAME=System App
NEXT_PUBLIC_USE_MOCK_API=false
NEXT_PUBLIC_SITE_URL=http://system.local

# Optional BE deploy overrides (public defaults are in be/config.yaml)
# OAUTH_REDIRECT_URL=http://system.local:8080/auth/callback
# CORS_ORIGINS=http://system.local,http://system.local:8080,http://localhost:8080

# --- Fallback when port 80 is already in use ---
# NGINX_HTTP_PORT=8080
# NEXT_PUBLIC_API_BASE_URL=http://system.local:8080/api
# NEXT_PUBLIC_SITE_URL=http://system.local:8080
# OAUTH_REDIRECT_URL=http://system.local:8080/auth/callback
# CORS_ORIGINS=http://system.local,http://system.local:8080,http://localhost,http://localhost:8080
